# Guardian MVP — required environment variables (no secret values here).
# Copy to .env (or set in your host's secret store) and fill in real values.
# Every variable consumed by the TS server (server/**) is listed here.

# ---------------------------------------------------------------------------
# Database — Prisma connection string.
# For PostgreSQL (provider-agnostic / Azure-exit path):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=GUARDIAN&connection_limit=30&pool_timeout=10"
# For SQL Server (legacy Azure):
#   DATABASE_URL="sqlserver://HOST:1433;database=DBNAME;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=false"
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=GUARDIAN&connection_limit=30&pool_timeout=10"

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Secret used to sign JWT tokens. Use a random 32+ byte hex string.
JWT_SECRET="<random-32+-byte-hex>"

# How long issued tokens remain valid (parsed by the jsonwebtoken library).
# Optional — defaults to "24h" if not set.
JWT_EXPIRES_IN="24h"

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# TCP port the Express server listens on.
# Optional — defaults to 3001 if not set.
PORT=3001

# Runtime environment. Set to "production" in hosted deployments.
NODE_ENV="production"

# ---------------------------------------------------------------------------
# Frontend base URL
# Used to build links in transactional emails (password-reset, verification,
# invite, request-assignment). Must NOT have a trailing slash.
# ---------------------------------------------------------------------------
FRONTEND_URL="https://your-domain.example"

# ---------------------------------------------------------------------------
# Email — Resend API
# RESEND_API_KEY is the canonical name.
# SMTP_PASSWORD is a legacy alias that also works (backward-compat).
# You only need to set one of them; RESEND_API_KEY takes precedence.
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Legacy alias — set this instead of RESEND_API_KEY if you have older config.
# Optional if RESEND_API_KEY is set.
SMTP_PASSWORD="re_xxxxxxxxxxxxxxxxxxxx"

# "From" address shown on all outbound emails.
# Optional — defaults to "support@shieldlytics.com" if not set.
EMAIL_FROM="support@your-domain.example"

# URL of the logo image embedded in transactional email HTML.
# Optional — defaults to https://shieldlytics.com/logo.png if not set.
EMAIL_LOGO_URL="https://your-domain.example/logo.png"

# ---------------------------------------------------------------------------
# Error notifications (optional)
# If set, server-level unhandled errors are emailed to this address.
# If not set, error emails fall back to EMAIL_FROM.
# ---------------------------------------------------------------------------
ERROR_NOTIFY_EMAIL="ops-alerts@your-domain.example"

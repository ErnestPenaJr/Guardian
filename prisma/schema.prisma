  SysStartTime                 DateTime                   @default(dbgenerated("sysutcdatetime()"), map: "DF_FIELDS_SysStart")
  SysEndTime                   DateTime                   @default(dbgenerated("CONVERT([datetime2],'9999-12-31 23:59:59.9999999')"), map: "DF_FIELDS_SysEnd")
  FIELD_LOOKUP_DISPLAY_TYPE_ID Int?
  ORGANIZATION_ID              Int?

generator client {
  provider        = "prisma-client-js"
  engineType      = "binary"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "windows"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
  schemas  = ["GUARDIAN"]
}

model ATTACHMENTS {
  ATTACHMENT_ID  Int      @id(map: "PK_ATTACHMENTS") @default(autoincrement())
  REQUEST_ID     Int
  FILE_NAME      String   @db.VarChar(100)
  ATTACHMENT     Bytes?
  COMPANY_ID     Int?
  CREATE_USER_ID Int?
  UPDATE_USER_ID Int?
  CREATE_DATE    DateTime @default(now(), map: "DF__ATTACHMEN__CREAT__2BFE89A6") @db.DateTime
  UPDATE_DATE    DateTime @default(now(), map: "DF__ATTACHMEN__UPDAT__2CF2ADDF") @db.DateTime
  
  WORK_PROGRESS  WORK_PROGRESS[]

  @@schema("GUARDIAN")
}

model WORK_PROGRESS {
  WORK_PROGRESS_ID        Int      @id(map: "PK_WORK_PROGRESS") @default(autoincrement())
  REQUEST_ID              Int
  USER_ID                 Int
  COMPANY_ID              Int
  PROGRESS_TYPE           String   @default("note") @db.VarChar(50)  // note, milestone, status, task, document, form, system
  TITLE                   String   @db.VarChar(255)
  DESCRIPTION             String?  @db.VarChar(2000)
  HOURS_WORKED            Decimal? @db.Decimal(5,2)
  STATUS_UPDATE           String?  @db.VarChar(100)
  RELATED_ATTACHMENT_ID   Int?
  IS_MILESTONE            Boolean  @default(false)
  IS_VISIBLE_TO_REQUESTOR Boolean  @default(true)
  IS_SYSTEM_GENERATED     Boolean  @default(false)
  RELATED_TASK_ID         Int?     // Link to TASKS table if task-related
  STATUS_FROM             String?  @db.VarChar(50)   // Previous status for status changes
  STATUS_TO               String?  @db.VarChar(50)   // New status for status changes  
  EVENT_DATA              String?  @db.VarChar(4000) // JSON data for additional context
  CREATE_DATE             DateTime @default(now()) @db.DateTime
  UPDATE_DATE             DateTime @default(now()) @db.DateTime
  CREATE_USER_ID          Int?
  UPDATE_USER_ID          Int?
  
  // Relationships
  REQUEST                 REQUESTS     @relation(fields: [REQUEST_ID], references: [REQUEST_ID], onUpdate: NoAction, onDelete: NoAction, map: "FK_WORK_PROGRESS_REQUEST")
  USER                    USERS        @relation("WorkProgressUser", fields: [USER_ID], references: [USER_ID], onUpdate: NoAction, onDelete: NoAction, map: "FK_WORK_PROGRESS_USER")
  RELATED_ATTACHMENT      ATTACHMENTS? @relation(fields: [RELATED_ATTACHMENT_ID], references: [ATTACHMENT_ID], onUpdate: NoAction, onDelete: NoAction, map: "FK_WORK_PROGRESS_ATTACHMENT")

  @@index([REQUEST_ID, COMPANY_ID])
  @@index([PROGRESS_TYPE])
  @@index([IS_MILESTONE])
  @@index([CREATE_DATE])
  @@schema("GUARDIAN")
}

model COMPANY {
  COMPANY_ID     Int              @id(map: "PK__COMPANY__73B8DCFF3D624EE3") @default(autoincrement())
  NAME           String           @db.NVarChar(255)
  ADDRESS        String?          @db.NVarChar(255)
  PHONE          String?          @db.NVarChar(50)
  CREATED_AT     DateTime         @default(now(), map: "DF__COMPANY__CREATED__1387E197") @db.DateTime
  COMPANY_INFO   COMPANY_INFO[]
  FORMS          FORMS[]
  FORMS_INSTANCE FORMS_INSTANCE[]

  @@schema("GUARDIAN")
}

model COMPANY_INFO {
  COMPANY_INFO_ID Int      @id(map: "PK__COMPANY___2099A60865741D46") @default(autoincrement())
  COMPANY_ID      Int
  USER_ID         Int
  WORKSPACE_NAME  String?  @db.NVarChar(255)
  ROLE            String?  @db.NVarChar(100)
  TEAM_SIZE       String?  @db.NVarChar(50)
  COMPANY_SIZE    String?  @db.NVarChar(50)
  CREATED_AT      DateTime @default(now(), map: "DF__COMPANY_I__CREAT__16644E42") @db.DateTime
  UPDATED_AT      DateTime @default(now(), map: "DF__COMPANY_I__UPDAT__1758727B") @db.DateTime
  COMPANY         COMPANY  @relation(fields: [COMPANY_ID], references: [COMPANY_ID], onUpdate: NoAction, map: "FK_COMPANY_INFO_COMPANY")
  USERS           USERS    @relation(fields: [USER_ID], references: [USER_ID], onUpdate: NoAction, map: "FK_COMPANY_INFO_USERS")

  @@schema("GUARDIAN")
}

model FIELD_LOOKUP_DISPLAY_TYPE {
  FIELD_LOOKUP_DISPLAY_TYPE_ID          Int      @id(map: "PK_FIELD_LOOKUP_DISPLAY_TYPE") @default(autoincrement())

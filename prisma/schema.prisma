  ISSUED_NOTICES                NOTICES[]       @relation("IssuedByUserNotices")
  NOTICE_RECIPIENTS             NOTICE_RECIPIENTS[] @relation("NoticeRecipientUser")
  NOTICE_READ_STATUS            NOTICE_READ_STATUS[] @relation("NoticeReadUser")

  // Add aliases for common field names used in the codebase
  @@map("USERS")
  @@schema("GUARDIAN")
}

model NOTIFICATIONS {
  NOTIFICATION_ID Int       @id(map: "PK_NOTIFICATIONS") @default(autoincrement())

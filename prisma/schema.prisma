model USERS {
  USER_ID                       Int            @id(map: "PK_USERS") @default(autoincrement())
  FIRST_NAME                    String?        @db.VarChar(30)
  LAST_NAME                     String?        @db.VarChar(30)
  EMAIL                         String         @db.VarChar(100)
  PIN                           String?        @db.VarChar(255)
  CREATE_USER_ID                Int?
  UPDATE_USER_ID                Int?
  CREATE_DATE                   DateTime?      @default(now(), map: "DF__USERS__CREATE_DA__6C190EBB") @db.DateTime
  UPDATE_DATE                   DateTime?      @default(now(), map: "DF__USERS__UPDATE_DA__6D0D32F4") @db.DateTime
  STATUS                        String?        @default("P", map: "DF__USERS__STATUS__6E01572D") @db.Char(1)

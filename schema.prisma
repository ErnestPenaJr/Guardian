generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
  engineType    = "binary"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model INVITES {
  INVITE_ID  Int       @id(map: "PK__INVITES__F55A9111738B9254") @default(autoincrement())
  EMAIL      String    @db.VarChar(100)
  ROLE_ID    Int
  COMPANY_ID Int
  TOKEN      String    @unique(map: "UQ__INVITES__05BE64ED01F60396") @db.VarChar(255)
  STATUS     String    @db.Char(1)
  EXPIRES_AT DateTime
  USED_AT    DateTime?
  CREATED_AT DateTime  @default(dbgenerated("sysdatetime()"), map: "DF__INVITES__CREATED__278EDA44")
}

model USER_ROLES {
  ROLE_ID    Int       @id(map: "PK__USER_ROL__5AC4D222B80E1489") @default(autoincrement())
  USER_ID    Int
  ROLE_NAME  String    @db.NVarChar(50)
  CREATED_AT DateTime? @default(now(), map: "DF__USER_ROLE__CREAT__17F790F9") @db.DateTime
  USERS      USERS     @relation(fields: [USER_ID], references: [USER_ID], onUpdate: NoAction, map: "FK_USER_ROLES_USER_ID")
}

model USERS {
  USER_ID       Int          @id(map: "PK__USERS__F3BEEBFF601CFE32") @default(autoincrement())
  EMAIL         String       @unique(map: "UQ__USERS__161CF724256F501E") @db.NVarChar(255)
  PASSWORD_HASH String?      @db.NVarChar(255)
  PIN           String?      @db.NVarChar(50)
  FIRST_NAME    String?      @db.NVarChar(100)
  LAST_NAME     String?      @db.NVarChar(100)
  STATUS        String?      @default("A", map: "DF__USERS__STATUS__1332DBDC") @db.Char(1)
  CREATED_AT    DateTime?    @default(now(), map: "DF__USERS__CREATED_A__14270015") @db.DateTime
  UPDATED_AT    DateTime?    @default(now(), map: "DF__USERS__UPDATED_A__151B244E") @db.DateTime
  USER_ROLES    USER_ROLES[]
}

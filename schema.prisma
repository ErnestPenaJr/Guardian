  EMAIL                         String         @db.VarChar(100)
  PIN                           Int?
  CREATE_USER_ID                Int?
  UPDATE_USER_ID                Int?
  CREATE_DATE                   DateTime @default(now()) @db.Timestamp(6)
  UPDATE_DATE                   DateTime @default(now()) @db.Timestamp(6)
  STATUS                        String         @default("P") @db.Char(1)
  SysStartTime                  DateTime @default(dbgenerated("now()"))
  SysEndTime                    DateTime @default(dbgenerated("'9999-12-31 23:59:59.999999'::timestamp"))
  PASSWORD_HASH                 String?        @db.VarChar(255)
  EMAIL_VALIDATED               Boolean        @default(false)
  EMAIL_VALIDATION_TOKEN        String?        @db.VarChar(255)
  PASSWORD_RESET_TOKEN          String?        @db.VarChar(255)
  COMPANY_ID                         Int?

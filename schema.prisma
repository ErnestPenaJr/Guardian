generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ATTACHMENTS {
  ATTACHMENT_ID       Int      @id(map: "PK_ATTACHMENTS") @default(autoincrement())
  REQUEST_ID          Int
  FILE_NAME           String   @db.VarChar(100)
  ATTACHMENT          Bytes?
  CREATE_USER_ID      Int?
  UPDATE_USER_ID      Int?
  CREATE_DATE         DateTime @default(now()) @db.Timestamp(6)
  UPDATE_DATE         DateTime @default(now()) @db.Timestamp(6)
  RESPONSE_MY_NOTICES RESPONSE_MY_NOTICE[]
}

model COMPANY {
  COMPANY_ID   Int            @id(map: "PK__COMPANY__73B8DCFF3D624EE3") @default(autoincrement())
  NAME         String         @db.VarChar(255)
  ADDRESS      String?        @db.VarChar(255)
  PHONE        String?        @db.VarChar(50)
  CREATED_AT   DateTime @default(now()) @db.Timestamp(6)
  COMPANY_INFO COMPANY_INFO[]
  FORMS        FORMS[]
}

model COMPANY_INFO {
  COMPANY_INFO_ID Int      @id(map: "PK__COMPANY___2099A60865741D46") @default(autoincrement())
  COMPANY_ID      Int
  USER_ID         Int
  WORKSPACE_NAME  String?  @db.VarChar(255)
  ROLE            String?  @db.VarChar(100)
  TEAM_SIZE       String?  @db.VarChar(50)
  COMPANY_SIZE    String?  @db.VarChar(50)
  CREATED_AT      DateTime @default(now()) @db.Timestamp(6)
  UPDATED_AT      DateTime @default(now()) @db.Timestamp(6)
  COMPANY         COMPANY  @relation(fields: [COMPANY_ID], references: [COMPANY_ID], onUpdate: NoAction, map: "FK_COMPANY_INFO_COMPANY")
  USERS           USERS    @relation(fields: [USER_ID], references: [USER_ID], onUpdate: NoAction, map: "FK_COMPANY_INFO_USERS")
}


  RESPONSE_MY_NOTICES                RESPONSE_MY_NOTICE[]
}

model MY_NOTICES {
  NOTICE_ID                  Int                        @id(map: "PK_MY_NOTICES") @default(autoincrement())
  NOTICE_TITLE               String                     @db.VarChar(255)
  SENSITIVITY_CLASSIFICATION String                     @db.VarChar(50)
  BUTTON_STATUS              String                     @db.VarChar(50)
  DISTRIBUTION_TYPE          String?                    @db.VarChar(50)
  NOTICE_BODY                String?                    @db.Text
  CREATE_USER_ID             Int?
  UPDATE_USER_ID             Int?
  CREATE_DATE                DateTime                   @default(now()) @db.Timestamp(6)
  UPDATE_DATE                DateTime?                  @db.Timestamp(6)
  COMPANY_ID                 Int?
  // Securities Notice MVP additions (Phase 0)
  TEMPLATE_FORM_ID                Int?
  NOTICE_STATUS                   String    @default("DRAFT") @db.VarChar(40)
  SUBMITTED_BY                    Int?
  SUBMITTED_AT                    DateTime? @db.Timestamp(6)
  APPROVED_BY                     Int?
  APPROVED_AT                     DateTime? @db.Timestamp(6)
  REJECTED_BY                     Int?
  REJECTED_AT                     DateTime? @db.Timestamp(6)
  REJECTION_REASON                String?   @db.VarChar(2000)
  SENT_AT                         DateTime? @db.Timestamp(6)
  DISCLAIMER_STATE                Boolean?
  FIRST_TIME_RECIPIENT_FLAG       Boolean?
  SUBPOENA_RIDER_ID               Int?
  ATTACHED_SUBPOENA_ATTACHMENT_ID Int?

  CREATE_USER                USERS?                     @relation(fields: [CREATE_USER_ID], references: [USER_ID], onDelete: NoAction, onUpdate: NoAction, map: "FK_MY_NOTICES_CREATE_USER")
  RECIPIENTS                 MY_NOTICE_RECIPIENTS[]
  RESPONSES                  RESPONSE_MY_NOTICE[]

  @@index([NOTICE_STATUS])
}

model MY_NOTICE_RECIPIENTS {
  NOTICE_RECIPIENT_ID Int        @id(map: "PK_MY_NOTICE_RECIPIENTS") @default(autoincrement())
  NOTICE_ID           Int
  USER_ID             Int

  MY_NOTICE           MY_NOTICES @relation(fields: [NOTICE_ID], references: [NOTICE_ID], onDelete: Cascade, onUpdate: NoAction, map: "FK_MY_NOTICE_RECIPIENTS_NOTICE")
  USER                USERS      @relation("MY_NOTICE_RECIPIENTS", fields: [USER_ID], references: [USER_ID], onDelete: Cascade, onUpdate: NoAction, map: "FK_MY_NOTICE_RECIPIENTS_USER")

  @@unique([NOTICE_ID, USER_ID], map: "UQ_MY_NOTICE_RECIPIENTS")
  @@index([NOTICE_ID], map: "IX_MY_NOTICE_RECIP_NOTICE")
  @@index([USER_ID], map: "IX_MY_NOTICE_RECIP_USER")
}

model RESPONSE_MY_NOTICE {
  RESPONSE_MY_NOTICE_ID Int       @id(map: "PK_RESPONSE_MY_NOTICE") @default(autoincrement())
  MY_NOTICE_ID          Int
  USER_ID               Int?
  RESPONSE_TEXT          String?   @db.Text
  ATTACHMENT_ID          Int?
  CREATE_DATE            DateTime  @default(now()) @db.Timestamp(6)
  COMPANY_ID             Int?

  MY_NOTICE              MY_NOTICES  @relation(fields: [MY_NOTICE_ID], references: [NOTICE_ID], onDelete: NoAction, onUpdate: NoAction)
  USER                   USERS?      @relation(fields: [USER_ID], references: [USER_ID], onDelete: NoAction, onUpdate: NoAction)
  ATTACHMENT             ATTACHMENTS? @relation(fields: [ATTACHMENT_ID], references: [ATTACHMENT_ID], onDelete: NoAction, onUpdate: NoAction)

}

// Securities Notice MVP — audit log table (Phase 0 migration target).
// The Prisma client generated from this root schema exposes prisma.aUDIT_LOG
// for the writeAudit helper in server/lib/audit.ts.
model AUDIT_LOG {
  ENTRY_ID         BigInt    @id @default(autoincrement())
  EVENT_TYPE       String    @db.VarChar(64)
  ACTOR_USER_ID    Int?
  ACTOR_ROLE_ID    Int?
  TARGET_TYPE      String    @db.VarChar(32)
  TARGET_ID        String?   @db.VarChar(64)
  EVENT_DETAIL     String?   @db.Text
  COMPANY_ID       Int?
  FIRST_TIME_FLAG  Boolean?
  DISCLAIMER_STATE Boolean?
  CREATED_AT       DateTime  @default(now())

  @@index([COMPANY_ID, CREATED_AT])
  @@index([EVENT_TYPE])
  @@index([TARGET_TYPE, TARGET_ID])
}


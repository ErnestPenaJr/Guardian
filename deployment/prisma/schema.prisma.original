generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["microsoftSqlServer"]
  engineType      = "binary"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model ATTACHMENTS {
  ATTACHMENT_ID  Int      @id(map: "PK_ATTACHMENTS") @default(autoincrement())
  REQUEST_ID     Int
  FILE_NAME      String   @db.VarChar(100)
  ATTACHMENT     Bytes?
  CREATE_USER_ID Int?
  UPDATE_USER_ID Int?
  CREATE_DATE    DateTime @default(now(), map: "DF__ATTACHMEN__CREAT__2BFE89A6") @db.DateTime
  UPDATE_DATE    DateTime @default(now(), map: "DF__ATTACHMEN__UPDAT__2CF2ADDF") @db.DateTime
}

model COMPANY {
  COMPANY_ID   Int            @id(map: "PK__COMPANY__73B8DCFF3D624EE3") @default(autoincrement())
  NAME         String         @db.NVarChar(255)
  ADDRESS      String?        @db.NVarChar(255)
  PHONE        String?        @db.NVarChar(50)
  CREATED_AT   DateTime       @default(now(), map: "DF__COMPANY__CREATED__1387E197") @db.DateTime
  COMPANY_INFO COMPANY_INFO[]
}

model COMPANY_INFO {
  COMPANY_INFO_ID Int      @id(map: "PK__COMPANY___2099A60865741D46") @default(autoincrement())
  COMPANY_ID      Int
  USER_ID         Int
  WORKSPACE_NAME  String?  @db.NVarChar(255)
  ROLE            String?  @db.NVarChar(100)
  TEAM_SIZE       String?  @db.NVarChar(50)
  COMPANY_SIZE    String?  @db.NVarChar(50)
  CREATED_AT      DateTime @default(now(), map: "DF__COMPANY_I__CREAT__16644E42") @db.DateTime
  UPDATED_AT      DateTime @default(now(), map: "DF__COMPANY_I__UPDAT__1758727B") @db.DateTime
  COMPANY         COMPANY  @relation(fields: [COMPANY_ID], references: [COMPANY_ID], onUpdate: NoAction, map: "FK_COMPANY_INFO_COMPANY")
  USERS           USERS    @relation(fields: [USER_ID], references: [USER_ID], onUpdate: NoAction, map: "FK_COMPANY_INFO_USERS")
}

model FIELD_LOOKUP_DISPLAY_TYPE {
  FIELD_LOOKUP_DISPLAY_TYPE_ID          Int      @id(map: "PK_FIELD_LOOKUP_DISPLAY_TYPE") @default(autoincrement())
  FIELD_LOOKUP_DISPLAY_TYPE_DESCRIPTION String   @db.VarChar(50)
  SORT_ORDER                            Int?
  FIELDS                                FIELDS[]
}

model FIELD_TYPE {
  FIELD_TYPE_ID   Int      @id(map: "PK_FIELD_TYPE") @default(autoincrement())
  FIELD_TYPE_DESC String   @db.VarChar(50)
  SORT_ORDER      Int?
  FIELDS          FIELDS[]
}

model FIELDS {
  FIELD_ID                     Int                        @id(map: "PK_FIELD") @default(autoincrement())
  FIELD_NAME                   String                     @db.VarChar(50)
  FIELD_TYPE_ID                Int
  DISPLAY_FORMAT               String?                    @db.VarChar(30)
  HAS_LOOKUP                   Boolean                    @default(false, map: "DF__FIELDS__HAS_LOOK__52AE4273")
  IS_PUBLIC                    Boolean                    @default(false, map: "DF__FIELDS__IS_PUBLI__53A266AC")
  IS_ACTIVE                    Boolean                    @default(false, map: "DF__FIELDS__IS_ACTIV__54968AE5")
  IS_DELETED                   Boolean                    @default(false, map: "DF__FIELDS__IS_DELET__558AAF1E")
  IS_REQUIRED                  Boolean                    @default(false, map: "DF__FIELDS__IS_REQUI__567ED357")
  IS_SENSITIVE                 Boolean                    @default(false, map: "DF__FIELDS__IS_SENSI__5772F790")
  CAN_SELECT_MULIPLE           Boolean                    @default(false, map: "DF__FIELDS__CAN_SELE__58671BC9")
  CREATE_USER_ID               Int?
  UPDATE_USER_ID               Int?
  CREATE_DATE                  DateTime                   @default(now(), map: "DF__FIELDS__CREATE_D__595B4002") @db.DateTime
  UPDATE_DATE                  DateTime                   @default(now(), map: "DF__FIELDS__UPDATE_D__5A4F643B") @db.DateTime
  SysStartTime                 DateTime                   @default(dbgenerated("sysutcdatetime()"), map: "DF_FIELDS_SysStart")
  SysEndTime                   DateTime                   @default(dbgenerated("CONVERT([datetime2],'9999-12-31 23:59:59.9999999')"), map: "DF_FIELDS_SysEnd")
  FIELD_LOOKUP_DISPLAY_TYPE_ID Int?
  ORGANIZATION_ID              Int?
  FIELD_LOOKUP_DISPLAY_TYPE    FIELD_LOOKUP_DISPLAY_TYPE? @relation(fields: [FIELD_LOOKUP_DISPLAY_TYPE_ID], references: [FIELD_LOOKUP_DISPLAY_TYPE_ID], onDelete: NoAction, onUpdate: NoAction, map: "FK__FIELDS__FIELD_LO__7BB05806")
  ORGANIZATIONS                ORGANIZATIONS?             @relation(fields: [ORGANIZATION_ID], references: [ORGANIZATION_ID], onDelete: NoAction, onUpdate: NoAction, map: "FK__FIELDS__ORGANIZA__0539C240")
  FIELD_TYPE                   FIELD_TYPE                 @relation(fields: [FIELD_TYPE_ID], references: [FIELD_TYPE_ID], onUpdate: NoAction, map: "FK__FIELDS__UPDATE_D__5B438874")
  FIELDS_LOOKUP                FIELDS_LOOKUP[]
  FORMS_FIELDS                 FORMS_FIELDS[]             @ignore
  FORMS_GROUPS_FIELDS          FORMS_GROUPS_FIELDS[]      @ignore
  FORMS_INSTANCE_VALUES        FORMS_INSTANCE_VALUES[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model FIELDS_HISTORY {
  FIELD_ID                     Int
  FIELD_NAME                   String   @db.VarChar(50)
  FIELD_TYPE_ID                Int
  DISPLAY_FORMAT               String?  @db.VarChar(30)
  HAS_LOOKUP                   Boolean
  IS_PUBLIC                    Boolean
  IS_ACTIVE                    Boolean
  IS_DELETED                   Boolean
  IS_REQUIRED                  Boolean
  IS_SENSITIVE                 Boolean
  CAN_SELECT_MULIPLE           Boolean
  CREATE_USER_ID               Int?
  UPDATE_USER_ID               Int?
  CREATE_DATE                  DateTime @db.DateTime
  UPDATE_DATE                  DateTime @db.DateTime
  SysStartTime                 DateTime
  SysEndTime                   DateTime
  FIELD_LOOKUP_DISPLAY_TYPE_ID Int?
  ORGANIZATION_ID              Int?

  @@index([SysEndTime, SysStartTime], map: "ix_FIELDS_HISTORY", clustered: true)
  @@ignore
}

model FIELDS_LOOKUP {
  FIELD_LOOKUP_ID    Int      @id(map: "PK_FIELDS_LOOKUP") @default(autoincrement())
  FIELD_ID           Int
  LOOKUP_CODE        String   @db.VarChar(50)
  LOOKUP_DESCRIPTION String   @db.VarChar(100)
  SORT_ORDER         Int?
  CREATE_USER_ID     Int?
  UPDATE_USER_ID     Int?
  CREATE_DATE        DateTime @default(now(), map: "DF__FIELDS_LO__CREAT__703EA55A") @db.DateTime
  UPDATE_DATE        DateTime @default(now(), map: "DF__FIELDS_LO__UPDAT__7132C993") @db.DateTime
  FIELDS             FIELDS   @relation(fields: [FIELD_ID], references: [FIELD_ID], onUpdate: NoAction, map: "FK__FIELDS_LO__FIELD__7226EDCC")
}


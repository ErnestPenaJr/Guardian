{
  "EnvironmentSettings" : {
    "EmailHost": "HERE"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "foo" : ""
  },
  "SmtpSettings": {
    "Host": "",
    "Port": 25,
    "ByPass": true,
    "UseSsl": false,
    "UseCredentials": false,
    "User" : "",
    "Password": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.File", "Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File", 
        "Args": {
          "path": "Logs\\log.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithExceptionDetails"
    ],
    "Properties": {
      "ApplicationName": "guardian",
      "Environment": "PROD"
    }
  }
}